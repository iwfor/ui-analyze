#!/usr/bin/env ruby
# frozen_string_literal: true

$LOAD_PATH.unshift File.expand_path("../lib", __dir__)

require "ui_analyze"
require "optparse"

require "time"

options = {}
OptionParser.new do |opts|
  opts.banner = "Usage: ui-analyze [options] <path-to-support-dump>"
  opts.separator ""
  opts.separator "The path can be a directory or a .tar.gz support tarball."
  opts.separator ""
  opts.on("--from DATE", "Only show boots on or after DATE (YYYY-MM-DD)") do |v|
    options[:from] = Time.parse(v)
  rescue ArgumentError
    warn "Error: invalid --from date '#{v}' (expected YYYY-MM-DD)"
    exit 1
  end
  opts.on("--to DATE", "Only show boots on or before DATE (YYYY-MM-DD)") do |v|
    # End of the given day
    options[:to] = Time.parse(v) + 86_399
  rescue ArgumentError
    warn "Error: invalid --to date '#{v}' (expected YYYY-MM-DD)"
    exit 1
  end
  opts.on("--anon", "--anonymize", "Replace serials, UUIDs, MACs, and other identifiers with placeholders") do
    options[:anon] = true
  end
  opts.on("--completions SHELL", UiAnalyze::Completions::SHELLS, "Print shell completion script (bash, zsh, fish)") do |v|
    puts UiAnalyze::Completions.generate(v)
    exit
  end
  opts.on("-h", "--help", "Show this message") { puts opts; exit }
end.parse!

path = ARGV[0]
if path.nil? || path.empty?
  warn "Error: path to support dump is required"
  warn "Usage: ui-analyze <path-to-support-dump>"
  exit 1
end

unless File.exist?(path)
  warn "Error: #{path} does not exist"
  exit 1
end

UiAnalyze::CLI.run(path, from: options[:from], to: options[:to], anon: options[:anon])
